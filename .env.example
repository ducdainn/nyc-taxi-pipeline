# ── Postgres (Airflow metadata DB) ──────────────────
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── DuckDB ──────────────────────────────────────────
DUCKDB_PATH=/opt/duckdb/nyc_taxi.duckdb

# ── Airflow ─────────────────────────────────────────
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__FERNET_KEY=           # generated
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__WEBSERVER__SECRET_KEY=      # generated
AIRFLOW_CONN_SPARK_DEFAULT=spark://spark-master:7077

# ── Spark ────────────────────────────────────────────
SPARK_MASTER=spark://spark-master:7077
SPARK_DRIVER_MEMORY=2g
SPARK_EXECUTOR_MEMORY=2g

# ── Data Paths ───────────────────────────────────────
RAW_DATA_PATH=/opt/data/raw
PROCESSED_DATA_PATH=/opt/data/processed

# ── TLC Source ───────────────────────────────────────
TLC_BASE_URL=https://d37ci6vzurychx.cloudfront.net/trip-data
TLC_TAXI_TYPE=yellow                 # yellow | green | fhv

# ── Metabase ─────────────────────────────────────────
MB_DB_TYPE=postgres
MB_DB_HOST=postgres
MB_DB_PORT=5432
MB_DB_USER=metabase
MB_DB_PASS=metabase
MB_DB_DBNAME=metabase